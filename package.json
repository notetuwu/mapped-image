{
  "name": "mapped-image",
  "version": "0.3.1",
  "private": false,
  "license": "MIT",
  "description": "A React component that overlays a clickable, weighted row/column grid on top of one or more images, built on react-leaflet.",
  "keywords": [
    "react",
    "leaflet",
    "react-leaflet",
    "image",
    "grid",
    "overlay"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/notetuwu/mapped-image.git"
  },
  "homepage": "https://github.com/notetuwu/mapped-image#readme",
  "bugs": {
    "url": "https://github.com/notetuwu/mapped-image/issues"
  },
  "type": "module",
  "main": "dist/MappedImage.js",
  "module": "dist/MappedImage.js",
  "types": "dist/MappedImage.d.ts",
  "exports": {
    ".": {
      "types": "./dist/MappedImage.d.ts",
      "import": "./dist/MappedImage.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react-leaflet": "^5.0.0",
    "@types/leaflet": "^1.9.21"
  },
  "devDependencies": {
    "tsup": "^8.3.5"
  }
}